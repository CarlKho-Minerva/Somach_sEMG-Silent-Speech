\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Three-panel comparison of Study~A (chin + under-chin) and Study~B (chin + throat). \textbf  {Left:} 5-fold CV accuracy (Study~A 51.8\% $\pm $ 2.8\%, Study~B 48.9\% $\pm $ 3.1\%; dashed line = chance at 16.7\%). \textbf  {Center:} Per-class F1 scores showing complementary failure patterns---RIGHT is worst for Study~A (F1=0.33), LEFT for Study~B (F1=0.36). \textbf  {Right:} Cross-study transfer accuracy (A$\to $B 31.3\%, B$\to $A 25.2\%), confirming incompatible feature spaces.}}{2}{figure.caption.2}\protected@file@percent }
\newlabel{fig:comparison}{{1}{2}{Three-panel comparison of Study~A (chin + under-chin) and Study~B (chin + throat). \textbf {Left:} 5-fold CV accuracy (Study~A 51.8\% $\pm $ 2.8\%, Study~B 48.9\% $\pm $ 3.1\%; dashed line = chance at 16.7\%). \textbf {Center:} Per-class F1 scores showing complementary failure patterns---RIGHT is worst for Study~A (F1=0.33), LEFT for Study~B (F1=0.36). \textbf {Right:} Cross-study transfer accuracy (A$\to $B 31.3\%, B$\to $A 25.2\%), confirming incompatible feature spaces}{figure.caption.2}{}}
